{
  "scripts": {
    "format": "oxfmt \"**/*.{md,mdx,yaml,yml,json}\"",
    "format:check": "oxfmt --check \"**/*.{md,mdx,yaml,yml,json}\"",
    "build-bindings": "pnpm --filter=@tensorzero/tensorzero-node build-bindings",
    "generate-python-schemas": "cd crates/tensorzero-python && uv run --no-project generate_schema_types.py",
    "ui:dev": "pnpm --filter=tensorzero-ui dev",
    "ui:storybook": "pnpm --filter=tensorzero-ui storybook",
    "ui:test": "pnpm --filter=tensorzero-ui test",
    "ui:test:e2e": "pnpm --filter=tensorzero-ui test-e2e",
    "ui:test:e2e-base-path": "pnpm --filter=tensorzero-ui test-e2e-base-path",
    "tensorzero-node:test": "cd crates/tensorzero-node && pnpm test",
    "clean:node": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "oxfmt": "^0.35.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ],
    "overrides": {
      "@codemirror/state": "6.5.4",
      "glob": ">=10.5.0",
      "js-yaml": ">=4.1.1",
      "on-headers": ">=1.1.0",
      "qs": ">=6.14.1",
      "react-router": ">=7.12.0",
      "lodash": ">=4.18.0",
      "valibot": ">=1.2.0",
      "@lezer/highlight": "1.2.3",
      "brace-expansion": ">=5.0.5",
      "minimatch@3>brace-expansion": "^1.1.12",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "uuid": ">=14.0.0",
      "yaml": ">=2.8.3",
      "path-to-regexp": "^0.1.13"
    }
  }
}
